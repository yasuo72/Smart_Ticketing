PORT=4000
WEB_ORIGIN=http://localhost:5173
# Update this to match your local PostgreSQL user, password, port, and database.
# Example for a common local setup:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_ticketing?schema=public
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-a-long-random-string
AI_PROVIDER=groq
GROQ_API_KEY=gsk_replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Email
RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_FROM_EMAIL="AI Ticketing <support@example.com>"
SUPPORT_EMAIL=support@example.com
