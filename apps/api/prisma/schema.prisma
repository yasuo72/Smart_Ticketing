generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String
  name            String
  role            Role         @default(CUSTOMER)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tickets         Ticket[]     @relation("CustomerTickets")
  assignedTickets Ticket[]     @relation("AgentTickets")
  replies         Reply[]
  auditEvents     AuditEvent[] @relation("AuditActor")
}

enum Role {
  CUSTOMER
  AGENT
  ADMIN
}

model Ticket {
  id                  String       @id @default(cuid())
  subject             String
  description         String
  status              TicketStatus @default(OPEN)
  priority            Priority     @default(MEDIUM)
  category            String?
  aiSummary           String?
  aiSuggestedPriority Priority?
  customerId          String
  customer            User         @relation("CustomerTickets", fields: [customerId], references: [id])
  agentId             String?
  agent               User?        @relation("AgentTickets", fields: [agentId], references: [id])
  replies             Reply[]
  auditEvents         AuditEvent[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  resolvedAt          DateTime?
  closedAt            DateTime?
  notificationEmail   String?

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([priority])
  @@index([category])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  AUTO_RESOLVED
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Reply {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  body       String
  isAiDraft  Boolean  @default(false)
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([ticketId])
  @@index([authorId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])
  action    String
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([actorId])
}
